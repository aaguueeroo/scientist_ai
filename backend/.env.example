# Optional defaults when the client does not send X-OpenAI-API-Key / X-Tavily-API-Key
# and no keys are stored via PUT /settings/provider-api-keys (may be left empty).
OPENAI_API_KEY=
TAVILY_API_KEY=
# search = Tavily /search (single-query results). research = Tavily /research (report + sources; slower).
TAVILY_RETRIEVAL_MODE=search
# Only for research: mini | pro | auto
TAVILY_RESEARCH_MODEL=mini
MAX_REQUEST_USD=0.60
RATE_LIMIT_PER_MIN=30
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./ai_scientist.db
